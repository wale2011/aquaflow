{
  "expo": {
    "name": "AquaFlow",
    "slug": "aquaflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0EA5E9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aquaflow.lagos",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AquaFlow needs your location to find nearby water tanker drivers.",
        "NSLocationAlwaysUsageDescription": "AquaFlow uses your location to track deliveries.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0EA5E9"
      },
      "package": "com.aquaflow.lagos",
      "versionCode": 1,
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "aquaflow",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08b33eae-dcb4-473c-aa2d-5870ffc227d4"
      }
    },
    "owner": "aktheraja01",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/08b33eae-dcb4-473c-aa2d-5870ffc227d4"
    }
  }
}
